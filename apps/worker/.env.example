# Copy to .env for local development (never commit the copied file).
# Better Auth is the only private dashboard sign-in path.
# Create a GitHub OAuth App with this callback:
# http://localhost:8787/api/auth/callback/github
# BETTER_AUTH_SECRET=generate-at-least-32-random-characters
# BETTER_AUTH_URL=http://localhost:8787
# BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:8787,http://localhost:5200
# GITHUB_CLIENT_ID=your-local-github-client-id
# GITHUB_CLIENT_SECRET=your-local-github-client-secret
# Separate secret for short-lived live replay WebSocket tickets.
LIVE_TICKET_SECRET=dev-live-ticket-secret-000000000000
# Public demo workspace values. Demo is disabled unless both are set.
DEMO_PROJECT_ID=project_demo
DEMO_WRITE_KEY=or_live_demo0000000000000000000000000000
# Optional in local development. Production must use the exact HTTPS sharing origin.
# PUBLIC_PAGE_ORIGIN=http://localhost:8787
# Local/self-host analytics compatibility. Hosted production uses r2_sql after provisioning.
ANALYTICS_READ_BACKEND=d1
# R2 SQL is server-only. Do not set these unless a real warehouse is provisioned.
# R2_SQL_TOKEN=least-privilege-reader-token
# R2_SQL_ACCOUNT_ID=cloudflare-account-id
# R2_SQL_BUCKET=orange-replay-analytics-prod
# Internal physical-deletion API. Use a different random value in production.
# ANALYTICS_PURGE_RUNNER_TOKEN=generate-at-least-32-random-characters
# "1" enables /__test/* routes (seeding, debug). Never set in production.
DEV_TEST_ROUTES=1
# Optional: shrink DO timing thresholds for manual testing, e.g.
# TEST_TIMINGS={"segmentFlushMs":2000,"flushTailMs":3000,"closeMs":10000}
