{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "orange-replay-dev",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "compatibility_flags": ["nodejs_compat"],
  "version_metadata": {
    "binding": "CF_VERSION_METADATA",
  },
  "observability": {
    "enabled": true,
  },
  "vars": {
    "WORKER_ENV": "development",
    "ANALYTICS_READ_BACKEND": "d1",
    "ANALYTICS_EXPORT_ENABLED": "0",
    "ANALYTICS_DELETION_READ_VERSION": "v1",
  },
  "durable_objects": {
    "bindings": [
      { "name": "SESSION", "class_name": "SessionRecorder" },
      { "name": "PRESENCE", "class_name": "PresenceRegistry" },
    ],
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["SessionRecorder"] },
    { "tag": "v2", "new_sqlite_classes": ["PresenceRegistry"] },
  ],
  "r2_buckets": [{ "binding": "RECORDINGS", "bucket_name": "orange-replay-recordings" }],
  "kv_namespaces": [{ "binding": "CONFIG", "id": "local-config" }],
  "d1_databases": [
    {
      "binding": "IDX_00",
      "database_name": "orange-replay-idx-00",
      "database_id": "local-idx-00",
      "migrations_dir": "migrations",
    },
  ],
  "ratelimits": [
    {
      "name": "INGEST_LOOKUP_RATE_LIMITER",
      "namespace_id": "1001",
      "simple": { "limit": 300, "period": 60 },
    },
    {
      "name": "INGEST_PROJECT_RATE_LIMITER",
      "namespace_id": "1002",
      "simple": { "limit": 60000, "period": 60 },
    },
    {
      "name": "INGEST_SESSION_RATE_LIMITER",
      "namespace_id": "1003",
      "simple": { "limit": 12000, "period": 60 },
    },
    {
      "name": "DEMO_API_RATE_LIMITER",
      "namespace_id": "1004",
      "simple": { "limit": 600, "period": 60 },
    },
    {
      "name": "KEY_MANAGEMENT_RATE_LIMITER",
      "namespace_id": "1005",
      "simple": { "limit": 30, "period": 60 },
    },
    {
      "name": "PUBLIC_PAGE_RATE_LIMITER",
      "namespace_id": "1006",
      "simple": { "limit": 600, "period": 60 },
    },
    {
      "name": "ANALYTICS_ACTOR_RATE_LIMITER",
      "namespace_id": "1007",
      "simple": { "limit": 30, "period": 60 },
    },
    {
      "name": "ANALYTICS_PROJECT_RATE_LIMITER",
      "namespace_id": "1008",
      "simple": { "limit": 300, "period": 60 },
    },
    {
      "name": "ANALYTICS_GLOBAL_RATE_LIMITER",
      "namespace_id": "1009",
      "simple": { "limit": 600, "period": 60 },
    },
    {
      "name": "LIVE_TICKET_RATE_LIMITER",
      "namespace_id": "1010",
      "simple": { "limit": 30, "period": 60 },
    },
  ],
  "queues": {
    "producers": [{ "binding": "FINALIZE_QUEUE", "queue": "or-session-finalized" }],
    "consumers": [
      {
        "queue": "or-session-finalized",
        "max_batch_size": 100,
        "max_batch_timeout": 5,
        "max_retries": 10,
        "dead_letter_queue": "or-dlq",
      },
    ],
  },
  "triggers": {
    "crons": ["*/5 * * * *", "7,22,37,52 * * * *"],
  },
  "env": {
    "production": {
      "name": "orange-replay",
      "workers_dev": true,
      "preview_urls": false,
      "routes": [{ "pattern": "public-page-origin.invalid", "custom_domain": true }],
      "compatibility_date": "2026-07-06",
      "compatibility_flags": ["nodejs_compat"],
      "version_metadata": {
        "binding": "CF_VERSION_METADATA",
      },
      "observability": {
        "enabled": true,
      },
      "secrets": {
        "required": [
          "BETTER_AUTH_SECRET",
          "BETTER_AUTH_URL",
          "BETTER_AUTH_TRUSTED_ORIGINS",
          "GITHUB_CLIENT_ID",
          "GITHUB_CLIENT_SECRET",
          "LIVE_TICKET_SECRET",
          "DEMO_PROJECT_ID",
          "DEMO_WRITE_KEY",
          "R2_SQL_TOKEN",
          "ANALYTICS_PURGE_RUNNER_TOKEN",
        ],
      },
      "vars": {
        "WORKER_ENV": "production",
        "ANALYTICS_READ_BACKEND": "REPLACE_WITH_PRODUCTION_ANALYTICS_READ_BACKEND",
        "ANALYTICS_EXPORT_ENABLED": "1",
        "ANALYTICS_DELETION_READ_VERSION": "REPLACE_WITH_PRODUCTION_ANALYTICS_DELETION_READ_VERSION",
        "R2_SQL_ACCOUNT_ID": "REPLACE_WITH_PRODUCTION_ACCOUNT_ID",
        "R2_SQL_BUCKET": "orange-replay-analytics-prod",
        "PUBLIC_PAGE_ORIGIN": "https://public-page-origin.invalid",
      },
      "assets": {
        "directory": "../dashboard/dist",
        "binding": "ASSETS",
        "run_worker_first": [
          "/api/*",
          "/internal/*",
          "/v1/*",
          "/login",
          "/_admin",
          "/_admin/*",
          "/demo",
          "/demo/*",
          "/projects",
          "/projects/*",
          "/p/*",
        ],
      },
      "durable_objects": {
        "bindings": [
          { "name": "SESSION", "class_name": "SessionRecorder" },
          { "name": "PRESENCE", "class_name": "PresenceRegistry" },
        ],
      },
      "r2_buckets": [{ "binding": "RECORDINGS", "bucket_name": "orange-replay-recordings-prod" }],
      "pipelines": [
        {
          "binding": "ANALYTICS_STREAM",
          "stream": "REPLACE_WITH_PRODUCTION_ANALYTICS_STREAM_ID",
        },
        {
          "binding": "ANALYTICS_DELETION_V2_STREAM",
          "stream": "REPLACE_WITH_PRODUCTION_ANALYTICS_DELETION_V2_STREAM_ID",
        },
      ],
      "kv_namespaces": [{ "binding": "CONFIG", "id": "REPLACE_WITH_PRODUCTION_KV_ID" }],
      "d1_databases": [
        {
          "binding": "IDX_00",
          "database_name": "orange-replay-idx-00-prod",
          "database_id": "REPLACE_WITH_PRODUCTION_D1_ID",
          "migrations_dir": "migrations",
        },
      ],
      "ratelimits": [
        {
          "name": "INGEST_LOOKUP_RATE_LIMITER",
          "namespace_id": "1001",
          "simple": { "limit": 300, "period": 60 },
        },
        {
          "name": "INGEST_PROJECT_RATE_LIMITER",
          "namespace_id": "1002",
          "simple": { "limit": 60000, "period": 60 },
        },
        {
          "name": "INGEST_SESSION_RATE_LIMITER",
          "namespace_id": "1003",
          "simple": { "limit": 12000, "period": 60 },
        },
        {
          "name": "DEMO_API_RATE_LIMITER",
          "namespace_id": "1004",
          "simple": { "limit": 600, "period": 60 },
        },
        {
          "name": "KEY_MANAGEMENT_RATE_LIMITER",
          "namespace_id": "1005",
          "simple": { "limit": 30, "period": 60 },
        },
        {
          "name": "PUBLIC_PAGE_RATE_LIMITER",
          "namespace_id": "1006",
          "simple": { "limit": 600, "period": 60 },
        },
        {
          "name": "ANALYTICS_ACTOR_RATE_LIMITER",
          "namespace_id": "1007",
          "simple": { "limit": 30, "period": 60 },
        },
        {
          "name": "ANALYTICS_PROJECT_RATE_LIMITER",
          "namespace_id": "1008",
          "simple": { "limit": 300, "period": 60 },
        },
        {
          "name": "ANALYTICS_GLOBAL_RATE_LIMITER",
          "namespace_id": "1009",
          "simple": { "limit": 600, "period": 60 },
        },
        {
          "name": "LIVE_TICKET_RATE_LIMITER",
          "namespace_id": "1010",
          "simple": { "limit": 30, "period": 60 },
        },
      ],
      "queues": {
        "producers": [{ "binding": "FINALIZE_QUEUE", "queue": "or-session-finalized-prod" }],
        "consumers": [
          {
            "queue": "or-session-finalized-prod",
            "max_batch_size": 100,
            "max_batch_timeout": 5,
            "max_retries": 10,
            "dead_letter_queue": "or-dlq-prod",
          },
        ],
      },
      "triggers": {
        "crons": ["*/5 * * * *", "7,22,37,52 * * * *"],
      },
    },
  },
}
