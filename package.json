{
  "name": "orange-replay",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "budget": "vp run @orange-replay/sdk#budget",
    "build:deploy": "node scripts/build-deploy.mjs --production",
    "bootstrap:prod": "node scripts/bootstrap-prod-project.mjs",
    "analytics:setup": "node scripts/setup-analytics.mjs",
    "analytics:inventory": "node scripts/inventory-r2.mjs",
    "analytics:backfill": "node scripts/backfill-analytics.mjs",
    "analytics:verify": "node scripts/verify-analytics-backfill.mjs",
    "analytics:smoke:prod": "node scripts/smoke-analytics-prod.mjs",
    "analytics:infra:test": "vp test scripts/analytics-infra.test.mjs",
    "db:check": "node scripts/check-d1-schema.mjs",
    "db:generate": "node scripts/create-d1-migration.mjs",
    "db:migrate:local": "node scripts/apply-d1-migrations.mjs orange-replay-idx-00 --local",
    "dev": "node scripts/dev.mjs",
    "deploy:cloudflare-build": "node scripts/deploy-production.mjs --cloudflare-build",
    "deploy:prod": "node scripts/deploy-production.mjs",
    "deploy:prod:d1": "ORANGE_REPLAY_PROD_ANALYTICS_READ_BACKEND=d1 vp run deploy:prod",
    "deploy:prod:compare": "ORANGE_REPLAY_PROD_ANALYTICS_READ_BACKEND=compare vp run deploy:prod",
    "deploy:prod:r2-sql": "ORANGE_REPLAY_PROD_ANALYTICS_READ_BACKEND=r2_sql vp run deploy:prod",
    "deploy:prod:rollback": "node scripts/deploy-prod-rollback.mjs",
    "deploy:prod:rollback:rebuild": "node scripts/deploy-prod-rebuild-rollback.mjs",
    "deploy:prod:dry-run": "node scripts/prepare-cloudflare-build-config.mjs && node scripts/build-deploy.mjs --production && vp exec --filter @orange-replay/worker -- wrangler deploy --config wrangler.cloudflare-build.jsonc --env production --dry-run --outdir dist/prod-dry-run --keep-vars",
    "mirror-template": "node scripts/mirror-template.mjs",
    "ready": "vp check && vp run -r test && vp run -r build",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@babel/core": "catalog:",
    "@rolldown/plugin-babel": "catalog:",
    "@types/babel__core": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260704.1",
    "babel-plugin-react-compiler": "catalog:",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "engines": {
    "node": ">=22.18.0"
  },
  "packageManager": "pnpm@11.9.0"
}
